{
  "manifestVersion": 5,
  "id": "com.tfxconversioner.uxp",
  "name": "TFX Conversioner",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "26.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "tfx-conversioner-panel",
      "label": {
        "default": "TFX Conversioner"
      },
      "minimumSize": {
        "width": 320,
        "height": 420
      },
      "maximumSize": {
        "width": 1600,
        "height": 2400
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 680
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 760
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request"
  }
}
